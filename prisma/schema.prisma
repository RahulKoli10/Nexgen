generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_BHP3TfFADid2@ep-cold-unit-aol6ulsz.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
  schemas  = ["mini_e_commerce"]
}

model Address {
  id        String  @id @default(cuid())
  label     String  @default("Home")
  fullName  String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean @default(false)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([userId])
  @@schema("mini_e_commerce")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model CartItem {
  id             String         @id @default(cuid())
  quantity       Int            @default(1)
  userId         String
  variantId      String
  addedAt        DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId])
  @@index([userId])
  @@schema("mini_e_commerce")
}

model Category {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  variantFields String[]  @default([])
  products      Product[]

  @@schema("mini_e_commerce")
}

model Notification {
  id        String    @id @default(cuid())
  type      NotifType
  title     String
  message   String
  link      String?
  isRead    Boolean   @default(false)
  userId    String?
  orderId   String?
  createdAt DateTime  @default(now())
  order     Order?    @relation(fields: [orderId], references: [id])
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
  @@schema("mini_e_commerce")
}

model Order {
  id                     String         @id @default(cuid())
  status                 OrderStatus    @default(PENDING)
  totalAmount            Int
  customerName           String
  customerEmail          String
  adminNote              String?
  userId                 String
  addressId              String
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  paymentMethod          String         @default("CASH_ON_DELIVERY")
  paymentStatus          String         @default("PENDING")
  paymentProvider        String?
  paymentId              String?
  paymentProviderOrderId String?
  paidAt                 DateTime?
  notifications          Notification[]
  address                Address        @relation(fields: [addressId], references: [id])
  user                   User           @relation(fields: [userId], references: [id])
  items                  OrderItem[]

  @@index([createdAt])
  @@index([customerEmail])
  @@index([status])
  @@index([userId])
  @@schema("mini_e_commerce")
}

 
model OrderItem {
  id             String         @id @default(cuid())
  quantity       Int
  productName    String
  variantName    String
  priceAtOrder   Int
  orderId        String
  variantId      String
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant        ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@schema("mini_e_commerce")
}

model Product {
  id             String           @id @default(cuid())
  name           String
  description    String?
  brand          String?
  slug           String           @unique
  isActive       Boolean          @default(true)
  categoryId     String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  category       Category         @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  variants       ProductVariant[]
  reviews        Review[]
  wishlists      Wishlist[]

  @@index([categoryId])
  @@index([isActive])
  @@index([slug])
  @@schema("mini_e_commerce")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  publicId  String?
  altText   String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@schema("mini_e_commerce")
}

model ProductVariant {
  id        String      @id @default(cuid())
  name      String
  sku       String      @unique
  price     Int
  stock     Int         @default(0)
  productId String
  cartItems CartItem[]
  orderItems OrderItem[]
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([stock])
  @@schema("mini_e_commerce")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@schema("mini_e_commerce")
}

model User {
  id                String         @id @default(cuid())
  name              String
  email             String         @unique
  password          String?
  role              Role           @default(USER)
  isVerified        Boolean        @default(false)
  verificationToken String?        @unique
  resetToken        String?
  resetTokenExpiry  DateTime?
  image             String?
  phone             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  isBanned          Boolean        @default(false)
  address           String?
  addresses         Address[]
  cartItems         CartItem[]
  notifications     Notification[]
  orders            Order[]
  reviews           Review[]
  wishlists         Wishlist[]

  @@index([email])
  @@index([role])
  @@schema("mini_e_commerce")
}

model Wishlist {
  id        String   @id @default(cuid())
  addedAt   DateTime @default(now())
  userId    String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
  @@schema("mini_e_commerce")
}
model SliderImage {
  id        String   @id @default(cuid())
  url       String   // Cloudinary URL
  publicId  String   // Cloudinary public_id — needed to delete from Cloudinary
  alt       String?  // SEO alt text
  title     String?  // optional overlay heading on the slide
  subtitle  String?  // optional overlay subtext
  linkUrl   String?  // clicking the slide goes here e.g. /products?category=sale
  order     Int      @default(0)   // drag-to-reorder position
  active    Boolean  @default(true) // admin can disable without deleting
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([order])
  @@schema("mini_e_commerce")
}
enum NotifType {
  ORDER_PLACED
  ORDER_CONFIRMED
  ORDER_SHIPPED
  ORDER_DELIVERED
  ORDER_CANCELLED
  NEW_ORDER
  LOW_STOCK
  ORDER_RETURN_REQUESTED
  ORDER_RETURNED

  @@schema("mini_e_commerce")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURNED

  @@schema("mini_e_commerce")
}

enum Role {
  USER
  ADMIN
  SELLER
  @@schema("mini_e_commerce")
}
